{
  "name": "@flittpayments/js-sdk",
  "description": "Flitt JavaScript SDK",
  "homepage": "https://github.com/flittpayments/js-sdk",
  "type": "module",
  "version": "2.0.10",
  "main": "dist/cjs/checkout.js",
  "module": "dist/esm/checkout.js",
  "unpkg": "dist/umd/checkout.js",
  "browser": "dist/umd/checkout.js",
  "author": {
    "name": "Flitt JavaScript Team",
    "url": "https://github.com/orgs/flittpayments/teams/javascript"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/checkout.js",
      "require": "./dist/cjs/checkout.js"
    }
  },
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest --collect-coverage",
    "jest": "node --experimental-vm-modules ./node_modules/.bin/jest --watch --collect-coverage",
    "watch": "./node_modules/.bin/rollup -c -w",
    "build": "./node_modules/.bin/rollup -c",
    "preversion": "npm test",
    "prepublishOnly": "npm run build",
    "version": "npm run build",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rollup": "^4.30.1",
    "rollup-plugin-copy": "^3.5.0"
  }
}
